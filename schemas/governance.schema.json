{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GovernanceExtraction",
  "type": "object",
  "required": ["doc_id", "index_type", "records", "extracted_at", "prompt_version"],
  "properties": {
    "doc_id": { "type": "string" },
    "index_type": { "type": "string", "const": "governance" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["anchor", "verbatim_quote", "confidence"],
        "properties": {
          "owner": { "type": ["string", "null"] },
          "approver": { "type": ["string", "null"] },
          "approval_date": {
            "type": ["string", "null"],
            "description": "ISO date (YYYY-MM-DD) or null"
          },
          "effective_date": { "type": ["string", "null"] },
          "next_review_date": { "type": ["string", "null"] },
          "regulatory_tier": {
            "type": ["string", "null"],
            "description": "Source's categorical label — do not re-map"
          },
          "use_cases": {
            "type": "array",
            "items": { "type": "string" }
          },
          "limitations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "anchor": {
            "type": "string",
            "pattern": "^[a-z0-9_]+#[a-z0-9-]+$"
          },
          "verbatim_quote": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "_quote_mismatch": { "type": "boolean" }
        }
      }
    },
    "extracted_at": { "type": "string", "format": "date" },
    "prompt_version": { "type": "string" },
    "error": { "type": "string" }
  }
}
