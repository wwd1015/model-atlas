# Copy to .env and fill in local values. The pipeline reads these paths.
# No API keys required — Claude Code is the executor for LLM steps.

RAW_DOCS_DIR=./raw
ARTIFACTS_DIR=./artifacts
KNOWLEDGE_DIR=./knowledge

# --- Atlas hub (all optional; defaults shown) ---
# ATLAS_PORT=8050          # or: python -m hub.app --port 8080
# ATLAS_HOST=127.0.0.1
# ATLAS_DEBUG=1
# ATLAS_CONTENT_DIR=./content
# ATLAS_KNOWLEDGE_DOCS=./knowledge/docs
# Copilot backend: auto (default — use the local Claude Code CLI when
# installed, else offline extractive) | claude (force) | extractive (force off)
# ATLAS_COPILOT=auto
# ATLAS_CLAUDE_MODEL=            # optional model override for `claude -p`
# ATLAS_COPILOT_TIMEOUT=90       # seconds before falling back to extractive
# Custom enterprise gateway adapter ("package.module:factory") — takes
# precedence over ATLAS_COPILOT. No keys in this repo either way.
# ATLAS_COPILOT_ADAPTER=
